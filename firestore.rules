rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function for admin/curator roles
    function isSAHSUser() {
      return request.auth != null && 
        request.auth.token.email != null && (
          request.auth.token.email.matches('(?i).*@senoiahistory\\.com') || 
          request.auth.token.email.matches('(?i)catnolan@senoiahistory\\.com') || 
          request.auth.token.email.matches('(?i)jeremywarren@senoiahistory\\.com') ||
          (exists(/databases/$(database)/documents/user_roles/$(request.auth.token.email.lower())) &&
           get(/databases/$(database)/documents/user_roles/$(request.auth.token.email.lower())).data.role in ['admin', 'curator'])
        );
    }

    // Helper function for setup check
    function isSetupComplete() {
      return exists(/databases/$(database)/documents/site_settings/setup) &&
             get(/databases/$(database)/documents/site_settings/setup).data.isComplete == true;
    }

    // Helper function to check if user is an active member
    function isActiveMember() {
      return request.auth != null && 
        request.auth.token.email != null &&
        exists(/databases/$(database)/documents/members/$(request.auth.token.email.lower())) &&
        get(/databases/$(database)/documents/members/$(request.auth.token.email.lower())).data.status == 'active' &&
        (
          get(/databases/$(database)/documents/members/$(request.auth.token.email.lower())).data.expiresAt == 'Never' ||
          get(/databases/$(database)/documents/members/$(request.auth.token.email.lower())).data.expiresAt >= 
            string(request.time.year()) + '-' + 
            (request.time.month() < 10 ? '0' + string(request.time.month()) : string(request.time.month())) + '-' + 
            (request.time.day() < 10 ? '0' + string(request.time.day()) : string(request.time.day()))
        );
    }

    // Helper function to check if user has access to a folder
    function isFolderOwnerOrCollaborator(folderId, userEmail) {
      return exists(/databases/$(database)/documents/research_folders/$(folderId)) && (
        get(/databases/$(database)/documents/research_folders/$(folderId)).data.get('ownerEmail', '').lower() == userEmail ||
        userEmail in get(/databases/$(database)/documents/research_folders/$(folderId)).data.get('sharedWith', [])
      );
    }

    // user_roles collection: admins/curators can read, only catnolan/jeremywarren can write roles OR first user during setup
    match /user_roles/{email} {
      allow get: if request.auth != null;
      allow list: if isSAHSUser();
      allow write: if request.auth != null && (
        request.auth.token.email.lower() == 'catnolan@senoiahistory.com' ||
        request.auth.token.email.lower() == 'jeremywarren@senoiahistory.com' ||
        (!isSetupComplete() && request.auth.token.email.lower() == email.lower() && request.resource.data.role == 'admin')
      );
    }

    // archive_items collection: Anyone can read, only SAHS users can write
    match /archive_items/{item} {
      allow read: if true;
      allow write: if isSAHSUser();
    }

    // library_books collection: Anyone can read, only SAHS users can write
    match /library_books/{bookId} {
      allow read: if true;
      allow write: if isSAHSUser();
    }

    // comments subcollection under archive_items: Everyone can read, only active members and curators can post
    match /archive_items/{itemId}/comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && (
        isSAHSUser() || 
        isActiveMember()
      );
      allow delete: if isSAHSUser() || (
        request.auth != null && 
        request.auth.token.email.lower() == resource.data.authorEmail.lower()
      );
    }

    // collections collection: Anyone can read, only SAHS users can write
    match /collections/{collection} {
      allow read: if true;
      allow write: if isSAHSUser();
    }

    // site_settings collection: Anyone can read, only SAHS users can write (or any user during initial setup)
    match /site_settings/{document} {
      allow read: if true;
      allow write: if isSAHSUser() || (request.auth != null && !isSetupComplete());
    }

    // settings collection: Anyone can read, only SAHS users can write
    match /settings/{document} {
      allow read: if true;
      allow write: if isSAHSUser();
    }

    // rooms collection for interactive map: Anyone can read, only SAHS users can write
    match /rooms/{room} {
      allow read: if true;
      allow write: if isSAHSUser();
    }

    // locations collection for interactive map: Anyone can read, only SAHS users can write
    match /locations/{location} {
      allow read: if true;
      allow write: if isSAHSUser();
    }

    // members collection: SAHS curators/admins can manage all, individuals can read their own membership status
    match /members/{email} {
      allow get: if request.auth != null;
      allow list: if isSAHSUser();
      allow write: if isSAHSUser();
    }

    // Deprecated research_folders subcollection (retained for backward compatibility/read-only safety if needed)
    match /members/{email}/research_folders/{folderId} {
      allow read, write: if isSAHSUser() || (request.auth != null && request.auth.token.email.lower() == email.lower());
    }

    // Deprecated research_notes subcollection (retained for backward compatibility/read-only safety if needed)
    match /members/{email}/research_notes/{itemId} {
      allow read, write: if isSAHSUser() || (request.auth != null && request.auth.token.email.lower() == email.lower());
    }

    // Root-level research_folders: Owners, Collaborators, and SAHS curators/admins can read/write
    match /research_folders/{folderId} {
      allow read: if isSAHSUser() || (
        request.auth != null && (
          (resource.data.ownerEmail != null && resource.data.ownerEmail == request.auth.token.email.lower()) || 
          (resource.data.sharedWith != null && request.auth.token.email.lower() in resource.data.sharedWith)
        )
      );
      allow create: if isSAHSUser() || (
        isActiveMember() && 
        request.resource.data.ownerEmail != null &&
        request.resource.data.ownerEmail == request.auth.token.email.lower()
      );
      allow update: if isSAHSUser() || (
        isActiveMember() && (
          (resource.data.ownerEmail != null && resource.data.ownerEmail == request.auth.token.email.lower()) || 
          (resource.data.sharedWith != null && request.auth.token.email.lower() in resource.data.sharedWith)
        )
      );
      allow delete: if isSAHSUser() || (
        isActiveMember() && 
        resource.data.ownerEmail != null &&
        resource.data.ownerEmail == request.auth.token.email.lower()
      );
    }

    // Root-level research_notes: Owners can read/write; Collaborators can read if note is not private
    match /research_notes/{noteId} {
      allow read: if isSAHSUser() || (
        request.auth != null && (
          (resource.data.ownerEmail != null && resource.data.ownerEmail == request.auth.token.email.lower()) || (
            resource.data.isPrivate != null &&
            resource.data.isPrivate == false && 
            resource.data.folderId != null &&
            resource.data.folderId != 'global' &&
            isFolderOwnerOrCollaborator(resource.data.folderId, request.auth.token.email.lower())
          )
        )
      );
      allow create: if isSAHSUser() || (
        isActiveMember() && 
        request.resource.data.ownerEmail != null &&
        request.resource.data.ownerEmail == request.auth.token.email.lower()
      );
      allow update: if isSAHSUser() || (
        isActiveMember() && 
        resource.data.ownerEmail != null &&
        resource.data.ownerEmail == request.auth.token.email.lower()
      );
      allow delete: if isSAHSUser() || (
        isActiveMember() && 
        resource.data.ownerEmail != null &&
        resource.data.ownerEmail == request.auth.token.email.lower()
      );
    }

    // notifications collection: Curators and admins can read and update them (to mark as read / dismiss)
    match /notifications/{notificationId} {
      allow read, update: if isSAHSUser();
    }

    // mail collection for Trigger Email extension: Authenticated users can write emails to trigger notifications
    match /mail/{mailId} {
      allow create: if request.auth != null;
    }

    // Root-level personal_pins: Only the owner can read/write their personal pins
    match /personal_pins/{pinId} {
      allow read: if request.auth != null && resource.data.ownerEmail != null && resource.data.ownerEmail == request.auth.token.email.lower();
      allow create: if (isSAHSUser() || isActiveMember()) && request.resource.data.ownerEmail != null && request.resource.data.ownerEmail == request.auth.token.email.lower();
      allow update: if (isSAHSUser() || isActiveMember()) && resource.data.ownerEmail != null && resource.data.ownerEmail == request.auth.token.email.lower() && request.resource.data.ownerEmail != null && request.resource.data.ownerEmail == request.auth.token.email.lower();
      allow delete: if (isSAHSUser() || isActiveMember()) && resource.data.ownerEmail != null && resource.data.ownerEmail == request.auth.token.email.lower();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
